FROM dxura/sbox:latest

# Create pterodactyl-compatible dirs
RUN mkdir -p /home/container/{data,download,logs}

# Move existing data out of the way (if it exists)
RUN mv /sbox/data /sbox/data.bak 2>/dev/null || true && \
    mv /sbox/download /sbox/download.bak 2>/dev/null || true && \
    mv /sbox/logs /sbox/logs.bak 2>/dev/null || true

# Create symlinks
RUN ln -s /home/container/data /sbox/data && \
    ln -s /home/container/download /sbox/download && \
    ln -s /home/container/logs /sbox/logs

# Fix permissions
RUN chown -R 1000:1000 /sbox /home/container

USER 1000
WORKDIR /sbox

CMD ["bash", "-c", "wine sbox-server.exe +game ${GAME} +hostname \"${HOSTNAME}\""]
